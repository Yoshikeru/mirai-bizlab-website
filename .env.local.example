# 本番サイトのURL (sitemap / robots / OG / alternates で利用)
NEXT_PUBLIC_SITE_URL=https://www.miraibizlab.co.th

# ----------------------------------------------------------------------
# お問い合わせフォーム → メール送信 (Resend)
# ----------------------------------------------------------------------
# 1. https://resend.com にサインアップ → API Keys → "Create API Key"
# 2. 発行された API キーを下記に設定 (Vercel ダッシュボードの環境変数にも)
# 3. 通知先メールは CONTACT_NOTIFY_EMAIL で指定
# 4. CONTACT_FROM_EMAIL は、Resend でドメイン認証が完了するまでは
#    デフォルト (onboarding@resend.dev) のままで OK。
#    miraibizlab.co.th を Resend で認証したら、自社ドメインに変更可能。

# Resend API キー (必須)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# 通知先メール (お問い合わせを受け取るアドレス)
CONTACT_NOTIFY_EMAIL=yoshida@miraibizlab.co.th

# 送信元メール (Resend でドメイン認証後に自社ドメインに変更)
# CONTACT_FROM_EMAIL=MIRAI BizLab <contact@miraibizlab.co.th>

# ----------------------------------------------------------------------
# AIチャットボット (サイト右下のアシスタント / Anthropic Claude)
# ----------------------------------------------------------------------
# 1. https://console.anthropic.com → API Keys → "Create Key"
# 2. 発行された API キーを下記に設定 (Vercel の環境変数にも)
# 3. 未設定時はチャットが「お問い合わせフォーム等へご連絡ください」と
#    案内するフォールバックで動作 (ビルドは通る)。

# Anthropic API キー (チャットボット用 / 必須)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# 使用モデル (任意 / 既定: claude-haiku-4-5)
# CHAT_MODEL=claude-haiku-4-5

# ----------------------------------------------------------------------
# 「タイ進出 戦略セッション」のオンライン決済 (Stripe Payment Link)
# ----------------------------------------------------------------------
# 1. https://dashboard.stripe.com にログイン
# 2. 商品カタログ → 商品を追加 (例: "タイ進出 戦略セッション", 価格 30,000 THB / 一括)
# 3. その商品から「Payment Link (決済リンク)」を作成 → URL をコピー
# 4. コピーした URL を下記に設定 (Vercel の環境変数にも同じ値を設定)
# 5. 未設定時は、サービスページの申込ボタンがお問い合わせページに遷移する
#    フォールバックで動作 (ビルドは通る)。
# NEXT_PUBLIC_STRATEGY_SESSION_URL=https://buy.stripe.com/xxxxxxxxxxxxxxxx
